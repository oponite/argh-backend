APP_NAME=Basketball Projection API
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Comma-separated list. For local development you can keep '*'.
CORS_ALLOW_ORIGINS=*

# Optional auth skeleton.
# When AUTH_ENABLED=true, requests to /api/auth/me require Bearer token in AUTH_TOKENS.
AUTH_ENABLED=false
AUTH_TOKENS=dev-token-1,dev-token-2

NBA_BASE_URL=https://stats.nba.com/stats
DEFAULT_TIMEOUT=15.0
USER_AGENT=Mozilla/5.0
